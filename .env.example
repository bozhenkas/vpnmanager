# токен бота — получить у @BotFather
BOT_TOKEN=1234567890:AABBCCddEEFFggHHIIjjKK

# домен RU-сервера (используется в подписках)
DOMAIN=ru.yourdomain.com

# 3X-UI панель (по умолчанию localhost, менять не нужно если бот на том же сервере)
PANEL_URL=https://127.0.0.1:25565/your-panel-path
PANEL_USER=admin
PANEL_PASS=changeme

# путь к базе данных бота (по умолчанию рядом со скриптом)
BOT_DB=/root/vpn-bot/bot.db
SUBS_DIR=/root/vpn-bot/subscriptions
