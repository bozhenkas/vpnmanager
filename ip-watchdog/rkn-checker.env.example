PROBE_TIMEOUT=10

# relay через RU сервер (TG заблокирован у ISP)
NOTIFY_URL=https://ru.goida.fun/notify
STATUS_URL=https://ru.goida.fun/rknstatus
NOTIFY_TOKEN=your_shared_secret_token

STATE_FILE=/var/lib/rkn-checker/state.json

# --- единый cluster-инвентарь (источник ENDPOINTS, без хардкода IP) ---
# если заданы — ENDPOINTS строятся из live-конфига; иначе fallback на PRIMARY/BACKUP/DOMAIN ниже.
# на прод-ноде: расшифрованный cluster.age + приватный ключ ноды.
CLUSTER_AGE_PATH=/etc/goida/cluster.age
CLUSTER_KEY_PATH=/etc/goida/age.key
CLUSTER_CACHE_PATH=/var/lib/rkn-checker/cluster-cache.json
# CLUSTER_HMAC_SECRET=  # секрет подписи (Phase 2); пусто = подпись не проверяется
# CLUSTER_CONFIG_MODULE=/opt/rkn-checker/cluster_config.py  # co-deploy рядом со скриптом

# fallback-дефолты (используются только если cluster-конфиг недоступен)
PRIMARY_IP=45.91.54.152
BACKUP_IP=45.91.53.93
DOMAIN=ru.goida.fun
YOUTUBE_PROXY=

# подтверждение блока: 3 пробы, разнесённые по окну ~10-30с (анти-ложные срабатывания)
CONFIRM_ATTEMPTS=3
CONFIRM_DELAY=10
CONFIRM_JITTER=5

# RKN_CHECK оставлен для backward compat, скрипт его больше не вызывает (прямые TCP/TLS пробы)
# RKN_CHECK=/opt/rkn-checker/rkn-check
