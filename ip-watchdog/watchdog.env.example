PRIMARY_IP=83.147.255.98
BACKUP_IP=83.147.255.168
DOMAIN=ru.goida.fun
CHECK_PORT=443

# Cloudflare — токен Edit zone DNS, ограничен зоной goida.fun
CF_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=96a673b4cce573f6735353674e9d6c7b

# алерты через relay-ручку на RU сервере (TG заблокирован у ISP)
NOTIFY_URL=https://ru.goida.fun/notify
NOTIFY_TOKEN=your_shared_secret_token

STATE_FILE=/var/lib/ip-watchdog/state
FAIL_THRESHOLD=3
PROBE_TIMEOUT=8
RETRY_DELAY=10
AUTO_RECOVERY=1
