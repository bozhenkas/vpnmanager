# /etc/ru-geo-analyzer/config.env — окружение для ru-geo-analyzer.service
# Скопировать в /etc/ru-geo-analyzer/config.env и поправить под прод.

# Путь к xray access.log RU-ноды.
# ВАЖНО: если remnanode пишет лог внутри контейнера — укажи host-путь bind-mount'а
# (проверь: docker inspect remnanode | grep -A3 remnanode | grep -i log).
RGA_LOG_PATH=/var/log/remnanode/access.log

# Состояние и выход (StateDirectory systemd создаёт /var/lib/ru-geo-analyzer).
RGA_STATE_PATH=/var/lib/ru-geo-analyzer/state.json
RGA_CANDIDATES_PATH=/var/lib/ru-geo-analyzer/candidates.json

# Воркеры детекта (RDAP/DNS). 2-4 достаточно, бережёт CPU и rate-limit RDAP.
RGA_WORKERS=3

# Пороги попадания в candidates.json (питон-промоутер ставит second gate сверху).
RGA_MIN_CONFIDENCE=0.75
RGA_MIN_HITS=3

# Период повторной проверки хоста (geo/владелец могут меняться) и флаша файлов.
RGA_RECHECK=24h
RGA_FLUSH_EVERY=60s

# Авто-промоут (флаг confirmed в candidates.json): хост получает confirmed=true
# и попадает в авто-обновление ТОЛЬКО при ≥MIN_SIGNALS независимых сигналах
# (Cymru+RTT), ≥MIN_HITS обращениях и возрасте ≥MIN_AGE. Иначе — только в ревью.
RGA_AUTO_MIN_SIGNALS=2
RGA_AUTO_MIN_HITS=5
RGA_AUTO_MIN_AGE=1h

# --- для ru-geo-updater.sh (единый обновлятор, daily timer) ---
RGA_REPO=/root/vpn-bot
RGA_SERVED_ROUTING=/var/www/html/routing.json
RGA_DENY_FILE=/etc/ru-geo-analyzer/deny.txt
RGA_RELOAD_CMD=systemctl restart vpn-bot.service
# RGA_BACKUP_DIR пустой по умолчанию: updater сам создаёт timestamped
# /root/deploy-backups/ru-geo-auto-<UTC>.

# Память: максимум отслеживаемых хостов (LRU-эвикция старейших).
RGA_MAX_HOSTS=100000

# Читать лог с начала при старте (false = только новые строки).
RGA_FROM_START=false

# Активный TCP-RTT — ВТОРОЙ независимый сигнал (физическая близость к RU).
# Демон живёт на RU, поэтому включён по умолчанию. На не-RU машине — false
# (RTT с другой локации не отражает близость к РФ).
# Замечание: RIPE RDAP/RIPEstat недостижимы с RU (нет v6/блок), rdap.org для
# RIPE-IP misroute'ит в ARIN — поэтому RDAP-сигнал с RU обычно пуст, и реально
# работающий консенсус = Cymru(реестр) + RTT(физика) + PTR.
RGA_RTT_ENABLE=true
