[Unit]
Description=goida unified WARNING/ERROR log collector (read-only)
After=docker.service
Wants=docker.service

[Service]
Type=oneshot
User=root
ExecStart=/usr/local/sbin/goida_warn_collect.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=goida-warn-collect

[Install]
WantedBy=multi-user.target
