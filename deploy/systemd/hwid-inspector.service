[Unit]
Description=Read-only HWID and user-agent inspector
After=docker.service
Wants=docker.service

[Service]
Type=oneshot
User=root
ExecStart=/usr/bin/python3 /opt/hwid-inspector/hwid_inspector.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hwid-inspector

[Install]
WantedBy=multi-user.target
